{
  "name": "@inkset/react",
  "version": "0.1.7",
  "description": "React bindings for Inkset, including the Inkset component and useInkset hook.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Davis Keene",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daviskeene/inkset.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/daviskeene/inkset/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/daviskeene/inkset/issues"
  },
  "keywords": [
    "inkset",
    "react",
    "markdown",
    "streaming",
    "renderer",
    "llm"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@inkset/core": "workspace:*",
    "@inkset/animate": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "jsdom": "^26.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
