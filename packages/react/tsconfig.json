{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@inkset/core": ["../core/src/index.ts"],
      "@inkset/animate": ["../animate/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["test/**/*", "dist/**/*"],
  "references": [
    { "path": "../core" },
    { "path": "../animate" }
  ]
}
